{
  "name": "tealus-mcp",
  "version": "0.8.1",
  "description": "Tealus MCP Server — Tealus Bot API as MCP tools (send_message / send_image / get_messages / get_message_media / read_document / search_messages / mark_tag_done / create_room / delete_room / list_rooms / join_room / mark_read). Install with: npx -y github:gamasenninn/tealus-mcp",
  "license": "MIT",
  "author": "Satoshi Ono",
  "homepage": "https://github.com/gamasenninn/tealus-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gamasenninn/tealus-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/gamasenninn/tealus-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tealus",
    "messenger",
    "ai",
    "chat",
    "bot",
    "claude",
    "anthropic"
  ],
  "main": "src/index.js",
  "bin": {
    "tealus-mcp": "src/index.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
